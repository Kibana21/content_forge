# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/story_studio

# Redis (Celery broker)
REDIS_URL=redis://default:<password>@<host>:<port>/0

# Gemini API (for AI text features)
GEMINI_API_KEY=ABCD
GEMINI_MODEL=gemini-2.5-flash

# Google Vertex AI (service account — for video generation)
GOOGLE_APPLICATION_CREDENTIALS=../video-key.json
GOOGLE_CLOUD_PROJECT=gen-lang-
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True

# JWT (for future auth)
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CORS
ALLOWED_ORIGINS=["http://localhost:3000"]

# Dev mode — set to true to bypass auth (hardcoded dev user)
DEV_MODE=true


VEO_MODEL=veo-3.1-generate-001                                                                                                                                               
VIDEO_OUTPUT_DIR=output/videos